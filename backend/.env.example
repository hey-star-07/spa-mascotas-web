# ===========================================
# PET SPA - Variables de Entorno
# ===========================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Reemplaza los valores de ejemplo con tus datos reales
# ===========================================

# Base de Datos PostgreSQL
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB?schema=SCHEMA
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5432/pet_spa_db?schema=public"

# JWT (JSON Web Tokens)
# Genera claves seguras en: https://www.grc.com/passwords.htm
# O usa: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GENERA_TU_PROPIA_CLAVE_SECRETA_DE_64_CARACTERES"
JWT_REFRESH_SECRET="GENERA_OTRA_CLAVE_SECRETA_DIFERENTE_DE_64_CARACTERES"
JWT_EXPIRATION="1h"
JWT_REFRESH_EXPIRATION="7d"

# Google OAuth 2.0
# 1. Ve a https://console.cloud.google.com/apis/credentials
# 2. Crea un proyecto > OAuth 2.0 Client ID > Web application
# 3. Agrega http://localhost:3000/api/auth/google/callback en Redirect URIs
GOOGLE_CLIENT_ID="TU_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="TU_CLIENT_SECRET"

# Email SMTP
# Para desarrollo, usa Mailtrap (GRATIS): https://mailtrap.io
# Para producción, usa SendGrid, Gmail o Amazon SES
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER="TU_USUARIO_MAILTRAP"
SMTP_PASS="TU_CONTRASEÑA_MAILTRAP"
EMAIL_FROM="noreply@petspa.com"
APP_URL="http://localhost:3000"

# Frontend
FRONTEND_URL="http://localhost:3001"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Seguridad
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
SESSION_EXPIRATION_MINUTES=30

# Entorno
NODE_ENV="development"
PORT=3000
